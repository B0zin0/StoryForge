<Application x:Class="StoryForge.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>

        <!-- ── Colours ── -->
        <Color x:Key="GoldColor">#FFAA00</Color>
        <Color x:Key="Gold2Color">#CC8800</Color>
        <Color x:Key="GreenColor">#55FF55</Color>
        <Color x:Key="RedColor">#FF4444</Color>
        <Color x:Key="GrayColor">#AAAAAA</Color>
        <Color x:Key="DarkColor">#0A0A0A</Color>
        <Color x:Key="StoneColor">#1A1A1A</Color>
        <Color x:Key="BorderColor">#333333</Color>
        <Color x:Key="PanelColor">#0C0C0C</Color>

        <SolidColorBrush x:Key="GoldBrush"   Color="{StaticResource GoldColor}"/>
        <SolidColorBrush x:Key="Gold2Brush"  Color="{StaticResource Gold2Color}"/>
        <SolidColorBrush x:Key="GreenBrush"  Color="{StaticResource GreenColor}"/>
        <SolidColorBrush x:Key="RedBrush"    Color="{StaticResource RedColor}"/>
        <SolidColorBrush x:Key="GrayBrush"   Color="{StaticResource GrayColor}"/>
        <SolidColorBrush x:Key="DarkBrush"   Color="{StaticResource DarkColor}"/>
        <SolidColorBrush x:Key="StoneBrush"  Color="{StaticResource StoneColor}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="PanelBrush"  Color="{StaticResource PanelColor}"/>

        <!-- ── Base button style ── -->
        <Style x:Key="McButton" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource StoneBrush}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Padding"      Value="18,8"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="#2a2a2a"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource GoldBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="#111111"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Nav button (topbar) ── -->
        <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource McButton}">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{StaticResource GrayBrush}"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="Padding"     Value="14,6"/>
        </Style>

        <!-- ── Gold accent button ── -->
        <Style x:Key="GoldButton" TargetType="Button" BasedOn="{StaticResource McButton}">
            <Setter Property="Background" Value="{StaticResource Gold2Brush}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{StaticResource GoldBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Dark text box ── -->
        <Style x:Key="McTextBox" TargetType="TextBox">
            <Setter Property="Background"        Value="#161616"/>
            <Setter Property="Foreground"        Value="White"/>
            <Setter Property="CaretBrush"        Value="White"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="BorderBrush"       Value="{StaticResource BorderBrush}"/>
            <Setter Property="Padding"           Value="6,5"/>
            <Setter Property="FontSize"          Value="11"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- ── Section title text ── -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource GoldBrush}"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="FontSize"    Value="22"/>
        </Style>

        <!-- ── Label text ── -->
        <Style x:Key="McLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource GrayBrush}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

    </Application.Resources>
</Application>
