<Window x:Class="StoryForge.Views.ModInstallDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="440" Height="300"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        ResizeMode="NoResize">

    <Border Background="#0C0C0C"
            BorderBrush="{StaticResource Gold2Brush}"
            BorderThickness="2">
        <StackPanel Margin="28,24">

            <TextBlock Text="INSTALL MOD"
                       Foreground="{StaticResource GoldBrush}"
                       FontFamily="/Assets/#Minecraft"
                       FontSize="14"
                       Margin="0,0,0,16"/>

            <!-- Description -->
            <TextBlock Text="Description:" Style="{StaticResource McLabel}"
                       Margin="0,0,0,4"/>
            <TextBox x:Name="DescBox" Style="{StaticResource McTextBox}"
                     Margin="0,0,0,12"/>

            <!-- Version -->
            <TextBlock Text="Version:" Style="{StaticResource McLabel}"
                       Margin="0,0,0,4"/>
            <TextBox x:Name="VersionBox" Style="{StaticResource McTextBox}"
                     Text="1.0" Margin="0,0,0,12"/>

            <!-- Category -->
            <TextBlock Text="Category:" Style="{StaticResource McLabel}"
                       Margin="0,0,0,4"/>
            <ComboBox x:Name="CategoryBox"
                      Background="#161616" Foreground="White"
                      BorderBrush="{StaticResource BorderBrush}"
                      Margin="0,0,0,20">
                <ComboBoxItem Content="Texture"  IsSelected="True"/>
                <ComboBoxItem Content="Script"/>
                <ComboBoxItem Content="Audio"/>
                <ComboBoxItem Content="Other"/>
            </ComboBox>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="INSTALL" Style="{StaticResource GoldButton}"
                        Margin="0,0,12,0" Click="Install_Click"/>
                <Button Content="CANCEL" Style="{StaticResource McButton}"
                        Click="Cancel_Click"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
