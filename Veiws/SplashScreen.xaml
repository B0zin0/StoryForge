<Window x:Class="StoryForge.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="480" Height="260"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        Topmost="True">

    <Border Background="#0A0A0A"
            BorderBrush="{StaticResource GoldBrush}"
            BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="4"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="4"/>
            </Grid.RowDefinitions>

            <!-- Top gold bar -->
            <Rectangle Grid.Row="0" Fill="{StaticResource GoldBrush}"/>

            <!-- Content -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                <TextBlock Text="STORYFORGE"
                           Foreground="{StaticResource GoldBrush}"
                           FontFamily="/Assets/#Minecraft"
                           FontSize="38"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#FFAA00" BlurRadius="22"
                                          ShadowDepth="0" Opacity="0.7"/>
                    </TextBlock.Effect>
                </TextBlock>

                <TextBlock Text="MCSM Launcher"
                           Foreground="{StaticResource GrayBrush}"
                           FontFamily="Segoe UI" FontSize="11"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,2"/>

                <TextBlock Text="v1.0"
                           Foreground="{StaticResource BorderBrush}"
                           FontFamily="Segoe UI" FontSize="9"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>

                <!-- Progress bar -->
                <Border Width="400" Height="12"
                        Background="#1A1A1A">
                    <Rectangle x:Name="ProgressBar"
                               Fill="{StaticResource GoldBrush}"
                               HorizontalAlignment="Left"
                               Width="0"/>
                </Border>

                <TextBlock x:Name="StatusLabel"
                           Text="Initializing..."
                           Foreground="{StaticResource GrayBrush}"
                           FontFamily="Segoe UI" FontSize="9"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Bottom gold bar -->
            <Rectangle Grid.Row="2" Fill="{StaticResource GoldBrush}"/>
        </Grid>
    </Border>
</Window>
