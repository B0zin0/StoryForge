<Page x:Class="StoryForge.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Black">

    <Grid>
        <Border Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource Gold2Brush}"
                BorderThickness="2"
                Width="580" VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Padding="32,28">
            <StackPanel>

                <TextBlock Text="SETTINGS"
                           Style="{StaticResource SectionTitle}"
                           FontFamily="/Assets/#Minecraft" FontSize="18"
                           HorizontalAlignment="Center"/>
                <Rectangle Height="2" Fill="{StaticResource GoldBrush}"
                           Margin="0,8,0,20"/>

                <!-- Season 1 path -->
                <TextBlock Text="Season 1 .exe:" Style="{StaticResource McLabel}"
                           Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="S1PathBox" Grid.Column="0"
                             Style="{StaticResource McTextBox}"/>
                    <Button Content="..." Grid.Column="1"
                            Style="{StaticResource McButton}"
                            Padding="12,5" Margin="6,0,0,0"
                            Click="Browse_S1"/>
                </Grid>

                <!-- Season 2 path -->
                <TextBlock Text="Season 2 .exe:" Style="{StaticResource McLabel}"
                           Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="S2PathBox" Grid.Column="0"
                             Style="{StaticResource McTextBox}"/>
                    <Button Content="..." Grid.Column="1"
                            Style="{StaticResource McButton}"
                            Padding="12,5" Margin="6,0,0,0"
                            Click="Browse_S2"/>
                </Grid>

                <!-- Music + volume -->
                <TextBlock Text="Music:" Style="{StaticResource McLabel}"
                           Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox x:Name="MusicCheck" Grid.Column="0"
                              Content="Enabled"
                              Foreground="{StaticResource GrayBrush}"
                              FontFamily="Segoe UI" FontSize="11"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0"
                              Checked="Music_Changed" Unchecked="Music_Changed"/>
                    <Slider x:Name="VolumeSlider" Grid.Column="1"
                            Minimum="0" Maximum="1"
                            TickFrequency="0.05"
                            IsSnapToTickEnabled="True"
                            VerticalAlignment="Center"
                            ValueChanged="Volume_Changed"/>
                    <TextBlock x:Name="VolumeLabel" Grid.Column="2"
                               Foreground="{StaticResource GrayBrush}"
                               FontFamily="Segoe UI" FontSize="11"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" Width="36"/>
                </Grid>

                <!-- Window size presets -->
                <TextBlock Text="Window size:" Style="{StaticResource McLabel}"
                           Margin="0,14,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button Content="900×600"  Style="{StaticResource McButton}"
                            Padding="10,5" Margin="0,0,8,0"
                            Click="Preset_900"/>
                    <Button Content="1280×720" Style="{StaticResource McButton}"
                            Padding="10,5" Margin="0,0,8,0"
                            Click="Preset_1280"/>
                    <Button Content="1600×900" Style="{StaticResource McButton}"
                            Padding="10,5" Margin="0,0,8,0"
                            Click="Preset_1600"/>
                    <Button Content="Fullscreen" Style="{StaticResource GoldButton}"
                            Padding="10,5"
                            Click="Preset_Full"/>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="SAVE" Style="{StaticResource GoldButton}"
                            Margin="0,0,12,0" Click="Save_Click"/>
                    <Button Content="BACK" Style="{StaticResource McButton}"
                            Click="Back_Click"/>
                </StackPanel>

                <TextBlock x:Name="SavedLabel" Text=""
                           Foreground="{StaticResource GreenBrush}"
                           FontFamily="Segoe UI" FontSize="11"
                           HorizontalAlignment="Center" Margin="0,10,0,0"/>

            </StackPanel>
        </Border>
    </Grid>
</Page>
